{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext js server.js",
    "start": "node server.js",
    "test": "jest --testPathPattern=__tests__ --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bcrypt": "^5.1.1",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3",
    "server": "file:"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.7",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.2.2"
  }
}
